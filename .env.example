# Server
PORT=8080
APP_ENV=development

# Database (jalankan via Docker, bukan install native)
DATABASE_URL=postgres://clinithink:password@localhost:5432/clinithink?sslmode=disable

# Redis (jalankan via Docker)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=ganti-dengan-random-string-minimal-32-karakter
JWT_EXPIRY=24h
